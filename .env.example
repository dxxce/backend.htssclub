# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3366
API_PREFIX=api
# Comma separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MongoDB (replica set required for transactions) ───
MONGO_URI=mongodb://localhost:27017/htss_club?replicaSet=rs0

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://192.168.1.86:6379

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RESET_PASSWORD_TTL=30m

# ── Cookies ───────────────────────────────────────────
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ── Uploads (local | s3) ──────────────────────────────
UPLOAD_DRIVER=local
UPLOAD_LOCAL_DIR=./uploads-store
UPLOAD_PUBLIC_BASE_URL=http://localhost:3366/static
AVATAR_MAX_BYTES=5242880
ATTACHMENT_MAX_BYTES=26214400
# Larger cap for video attachments (default 200MB)
VIDEO_MAX_BYTES=209715200

# ── S3 / MinIO (when UPLOAD_DRIVER=s3) ────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# ── Voice / SFU ───────────────────────────────────────
# Participants per voice channel before switching mesh P2P -> SFU.
VOICE_SFU_THRESHOLD=8
# LiveKit SFU (leave blank to force mesh-only mode).
LIVEKIT_URL=ws://192.168.1.86:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Default server ────────────────────────────────────
# New users are auto-joined to this server and cannot leave it.
# If DEFAULT_SERVER_ID is blank, one is bootstrapped on startup owned by
# DEFAULT_SERVER_OWNER_ID.
DEFAULT_SERVER_ID=6a1f7af1edfe2717c84d79c1
DEFAULT_SERVER_OWNER_ID=6a1ef376a6ac516fd24d4fb2

# ── Direct messages (Discord-style: TLS in transit + at-rest encryption) ──
# 32-byte secret for AES-256-GCM at-rest encryption of DM content. The server
# CAN read DMs (search/moderation); a leaked DB dump alone cannot.
DM_ENCRYPTION_KEY=change_me_dm_encryption_key_32bytes

# ── Games: Tiến Lên Miền Nam ──────────────────────────
# WAGER chop pricing: a black heo (♠/♣) costs this FRACTION of the bet amount;
# a red heo (♦/♥) costs DOUBLE. e.g. 0.5 with bet=200 -> black=100, red=200.
TIENLEN_CHOP_HEO_BET_RATIO=0.5
# RP the victim loses (and the chopper gains) per heo UNIT in RANKED mode
# (a red heo counts as 2 units).
TIENLEN_CHOP_HEO_RP=5
# Bonus RP awarded for an instant-win "tới trắng" hand (RANKED mode).
TIENLEN_INSTANT_WIN_RP=10
